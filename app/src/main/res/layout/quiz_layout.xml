<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/kbc_bg">

    <!-- Header with Question Count and Timer -->
    <View
        android:id="@+id/quiz_header"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:background="@color/kbc_blue_light"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/questionCount"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:text="Question 1/30"
        android:textColor="@color/kbc_gold"
        android:textSize="18sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="@+id/quiz_header"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@+id/quiz_header" />

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/timer_card"
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:layout_marginEnd="16dp"
        app:cardBackgroundColor="@color/kbc_purple"
        app:cardCornerRadius="25dp"
        app:layout_constraintBottom_toBottomOf="@+id/quiz_header"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@+id/quiz_header"
        app:strokeColor="@color/kbc_gold"
        app:strokeWidth="2dp">

        <TextView
            android:id="@+id/timer"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:text="10"
            android:textColor="@color/kbc_timer_red"
            android:textSize="20sp"
            android:textStyle="bold" />
    </com.google.android.material.card.MaterialCardView>

    <ProgressBar
        android:id="@+id/progressBar"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="4dp"
        android:max="30"
        android:progressDrawable="@android:drawable/progress_horizontal"
        android:progressTint="@color/kbc_gold"
        app:layout_constraintTop_toBottomOf="@+id/quiz_header" />

    <!-- Question Container -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/question_card"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        app:cardBackgroundColor="@color/kbc_blue_light"
        app:cardCornerRadius="16dp"
        app:layout_constraintTop_toBottomOf="@+id/progressBar"
        app:strokeColor="@color/kbc_gold"
        app:strokeWidth="2dp">

        <TextView
            android:id="@+id/questionText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="24dp"
            android:text="Which planet is known as the Red Planet?"
            android:textAlignment="center"
            android:textColor="@color/white"
            android:textSize="20sp"
            android:textStyle="bold" />
    </com.google.android.material.card.MaterialCardView>

    <!-- Options Group -->
    <RadioGroup
        android:id="@+id/optionsGroup"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        app:layout_constraintTop_toBottomOf="@+id/question_card">

        <RadioButton
            android:id="@+id/opt1"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginBottom="8dp"
            android:background="@drawable/kbc_option_bg"
            android:button="@null"
            android:paddingStart="24dp"
            android:text="Option 1"
            android:textColor="@color/white"
            android:textSize="16sp" />

        <RadioButton
            android:id="@+id/opt2"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginBottom="8dp"
            android:background="@drawable/kbc_option_bg"
            android:button="@null"
            android:paddingStart="24dp"
            android:text="Option 2"
            android:textColor="@color/white"
            android:textSize="16sp" />

        <RadioButton
            android:id="@+id/opt3"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginBottom="8dp"
            android:background="@drawable/kbc_option_bg"
            android:button="@null"
            android:paddingStart="24dp"
            android:text="Option 3"
            android:textColor="@color/white"
            android:textSize="16sp" />

        <RadioButton
            android:id="@+id/opt4"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:background="@drawable/kbc_option_bg"
            android:button="@null"
            android:paddingStart="24dp"
            android:text="Option 4"
            android:textColor="@color/white"
            android:textSize="16sp" />
    </RadioGroup>

    <!-- Submit Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/submitBtn"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_margin="16dp"
        android:backgroundTint="@color/kbc_gold"
        android:text="SUBMIT"
        android:textColor="@color/kbc_bg"
        android:textSize="18sp"
        android:textStyle="bold"
        app:cornerRadius="30dp"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
